{% extends 'base.html.twig' %}

{% block html_class %}h-full bg-white{% endblock %}
{% block body_class %}h-full antialiased text-gray-900 selection:bg-gray-200 selection:text-gray-900{% endblock %}
{% block title %}RunTracker{% endblock %}

{% block stylesheets %}
    <link rel="preconnect" href="https://fonts.bunny.net">
    <link href="https://fonts.bunny.net/css?family=inter:400,500,600,700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }
    </style>
{% endblock %}

{% block body %}
    <main class="flex min-h-full">
        <section class="relative hidden w-0 flex-1 overflow-hidden bg-gray-900 lg:block" aria-label="Running">
            <img class="absolute inset-0 h-full w-full object-cover" src="/images/runner.png" alt="Runner on a mountain road">
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900/80 via-gray-900/20 to-transparent" aria-hidden="true"></div>

            <div class="absolute left-12 top-10 flex items-center gap-2 text-white">
                {% include 'partials/_runner_icon.html.twig' %}
                <span class="text-lg font-semibold tracking-tight">RunTracker</span>
            </div>

            <div class="absolute bottom-12 left-12 text-white">
                <h2 class="mb-2 text-4xl font-bold leading-tight tracking-tight">One run<br>at a time.</h2>
                <p class="text-lg font-medium text-gray-300">Make it count.</p>
            </div>
        </section>

        <section class="flex flex-1 flex-col justify-center px-4 py-12 sm:px-6 lg:flex-none lg:px-20 xl:px-32" aria-label="Login form">
            <div class="mx-auto w-full max-w-sm lg:w-96">
                <div class="mb-8 flex items-center gap-2 text-gray-900 lg:hidden">
                    {% include 'partials/_runner_icon.html.twig' %}
                    <span class="text-lg font-semibold tracking-tight">RunTracker</span>
                </div>

                <header class="mb-10 text-center lg:text-left">
                    <h1 class="text-[26px] font-semibold tracking-tight text-gray-900">С возвращением</h1>
                    <p class="mt-2 text-[15px] text-gray-500">Войдите в систему, чтобы продолжить</p>
                </header>

                <form class="mt-8 space-y-6" action="#" method="post">
                    <input type="hidden" name="_token" value="">

                    <div>
                        <label for="login" class="mb-1.5 block text-xs font-medium text-gray-600">Логин</label>
                        <input
                            class="block w-full rounded-md border border-gray-200 px-3 py-2.5 text-gray-900 placeholder-gray-400 transition-colors focus:border-gray-900 focus:outline-none focus:ring-1 focus:ring-gray-900 sm:text-sm"
                            id="login"
                            name="login"
                            type="text"
                            autocomplete="username"
                            placeholder="user name"
                            required
                        >
                    </div>

                    <div>
                        <label for="password" class="mb-1.5 block text-xs font-medium text-gray-600">Пароль</label>
                        <div class="relative">
                            <input
                                class="block w-full rounded-md border border-gray-200 px-3 py-2.5 pr-10 text-gray-900 placeholder-gray-400 transition-colors focus:border-gray-900 focus:outline-none focus:ring-1 focus:ring-gray-900 sm:text-sm"
                                id="password"
                                name="password"
                                type="password"
                                autocomplete="current-password"
                                placeholder="••••••••"
                                required
                            >
                            <button class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 transition-colors hover:text-gray-600" type="button" aria-label="Показать пароль">
                                <svg class="h-[18px] w-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7Z" />
                                </svg>
                            </button>
                        </div>
                    </div>

                    <div class="flex items-center">
                        <input id="remember-me" name="remember" type="checkbox" class="h-4 w-4 rounded border-gray-300 text-gray-900 focus:ring-gray-900">
                        <label for="remember-me" class="ml-2 block text-sm text-gray-600">Запомнить меня</label>
                    </div>

                    <div class="pt-2">
                        <button class="flex w-full justify-center rounded-md border border-transparent bg-[#111827] px-4 py-2.5 text-sm font-medium text-white shadow-sm transition-colors hover:bg-black focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2" type="submit">
                            Войти
                        </button>
                    </div>
                </form>
            </div>
        </section>
    </main>
{% endblock %}
